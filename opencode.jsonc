{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.4-mini",
  "default_agent": "build",
  "compaction": {
    "auto": true,
    "prune": true,
  },
  "permission": {
    "bash": {
      // Git commands
      "git add *": "ask",
      "git branch *": "ask",
      "git checkout *": "ask",
      "git commit *": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge *": "ask",
      "git pull *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git status *": "allow",
      // Go commands
      "go build *": "allow",
      "go fmt *": "allow",
      "go test *": "allow",
      "go vet *": "allow",
      "gofmt *": "allow",
      "golangci-lint *": "allow",
      // File searching and manipulation
      "cp *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "mv *": "allow",
      "rg *": "allow",
      "rm *": "ask",
    },
  },
  "mcp": {
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["/Users/fepozopo/.local/bin/codebase-memory-mcp"],
    },
  },
}
