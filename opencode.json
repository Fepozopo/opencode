{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.4-mini",
  "default_agent": "build",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "bash": {
      "rm *": "ask",
      "git commit*": "ask",
      "git add*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "git status": "allow",
      "git log": "allow",
      "git diff": "allow",
      "git branch": "allow",
      "*": "ask"
    }
  }
}
